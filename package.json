    "@grammyjs/menu": "^1.3.1",
    "bullmq": "^5.80.8",
    "dotenv": "^17.4.2",
    "grammy": "^1.44.0",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "node-pg-migrate": "^9.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
