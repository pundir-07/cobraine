{
  "name": "telegram",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch src/index.ts",
    "worker:reminders": "tsx watch src/workers/worker.reminder.ts",
    "redis": "redis-server .redis/redis.conf",
    "redis:ping": "redis-cli -h 127.0.0.1 -p 6379 ping",
    "migrate:up": "node-pg-migrate up --migrations-dir ./migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir ./migrations --all",
    "migrate:create": "node-pg-migrate create"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
